# ── Server ────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────
# Local:  MONGO_URI=mongodb://localhost:27017/jec_buddy
# Atlas:  MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/jec_buddy
MONGODB_URI=mongodb://127.0.0.1:27017/jec_buddy

# ── Python ───────────────────────────────────────────────
# Path to the Python executable that has nltk + scikit-learn installed
PYTHON_PATH=python

# Path to the directory containing chatbot.py, *.pkl, college_intents.json
CHATBOT_DIR=../nlp

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
